{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "buttercup/events",
	"version": "1.0.0",
	"title": "Events",
	"category": "widgets",
	"icon": "calendar",
	"description": "Display upcoming or past events from the Buttercup events system.",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"textdomain": "buttercup",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"attributes": {
		"displayMode": {
			"type": "string",
			"default": "upcoming",
			"enum": [ "upcoming", "past" ]
		},
		"eventsToShow": {
			"type": "number",
			"default": 6
		},
		"showPastEventsLink": {
			"type": "boolean",
			"default": true
		}
	}
}
