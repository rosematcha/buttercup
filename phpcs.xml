<?xml version="1.0"?>
<ruleset name="Buttercup">
    <description>PHPCS rules for the Buttercup WordPress plugin.</description>

    <file>buttercup.php</file>
    <file>includes</file>
    <file>uninstall.php</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <config name="minimum_supported_wp_version" value="5.3"/>
    <config name="testVersion" value="7.2-"/>
    <config name="text_domain" value="buttercup"/>

    <!--
        The project's PHP style (4-space indent, Allman braces, non-Yoda
        conditions, compact operator spacing, short arrays / ternaries, //
        function comments) intentionally diverges from WordPress-Core
        formatting.  We include the full WordPress ruleset and then exclude
        every pure-formatting / docs sniff that conflicts, retaining all
        substantive checks: security, escaping, i18n, capability checks,
        database best practices, and PHP compatibility.
    -->

    <rule ref="WordPress">
        <!-- ── Filename conventions (procedural includes) ── -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>

        <!-- ── Indentation & whitespace ── -->
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>
        <exclude name="Generic.WhiteSpace.ArbitraryParenthesesSpacing"/>
        <exclude name="WordPress.WhiteSpace.ControlStructureSpacing"/>
        <exclude name="WordPress.WhiteSpace.OperatorSpacing"/>
        <exclude name="PEAR.Functions.FunctionCallSignature"/>
        <exclude name="Generic.Formatting.MultipleStatementAlignment"/>

        <!-- ── Brace style (project uses Allman, not K&R) ── -->
        <exclude name="Generic.Functions.OpeningFunctionBraceKernighanRitchie"/>

        <!-- ── Array & ternary syntax ── -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <exclude name="Universal.Operators.DisallowShortTernary"/>

        <!-- ── Condition style (project uses non-Yoda) ── -->
        <exclude name="WordPress.PHP.YodaConditions"/>

        <!-- ── Comment / doc style ── -->
        <exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
        <exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
    </rule>

    <rule ref="PHPCompatibilityWP"/>
</ruleset>
