<?xml version="1.0"?>
<ruleset name="Buttercup">
    <description>PHPCS rules for the Buttercup WordPress plugin.</description>

    <file>buttercup.php</file>
    <file>includes</file>
    <file>uninstall.php</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <config name="minimum_supported_wp_version" value="5.3"/>
    <config name="testVersion" value="7.2-"/>
    <config name="text_domain" value="buttercup"/>

    <rule ref="WordPress">
        <!-- Project uses procedural includes, not class-per-file convention -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>

        <!--
            The following rules enforce WordPress whitespace style, which conflicts
            with the project's established conventions (4-space indent, compact
            paren spacing, short array syntax). The substantive checks — security,
            escaping, i18n, capability checks — are retained.
        -->

        <!-- Project uses 4-space indentation, not tabs -->
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>

        <!-- Project uses short array syntax [] throughout -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

        <!-- Project uses compact spacing: if(!x) and func($arg), not if ( !x ) / func( $arg ) -->
        <exclude name="WordPress.WhiteSpace.ControlStructureSpacing"/>
        <exclude name="PEAR.Functions.FunctionCallSignature"/>
    </rule>

    <rule ref="PHPCompatibilityWP"/>
</ruleset>
